# QML DataFlow Studio — Environment Configuration
# Copy this file to .env and edit as needed:  cp .env.example .env

# Server
PORT=5000
FLASK_DEBUG=false
LOG_LEVEL=INFO

# Storage (defaults to project-local directories)
UPLOAD_DIR=uploads
MODELS_DIR=models
LOGS_DIR=logs

# Upload limits
MAX_UPLOAD_MB=50

# CORS origins (comma-separated, or * for all)
CORS_ORIGINS=*
